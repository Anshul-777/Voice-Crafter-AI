# ══════════════════════════════════════════════════════════════════════════════
# Voice-Crafter Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Voice-Crafter
ENVIRONMENT=development                 # development | production
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-USE-LONG-RANDOM-STRING-IN-PRODUCTION

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voicecrafter:voicecrafter@localhost:5432/voicecrafter
# For Docker: postgresql+asyncpg://voicecrafter:voicecrafter@postgres:5432/voicecrafter

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage ───────────────────────────────────────────────────────────────────
# Option 1: MinIO (self-hosted, recommended)
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_SECURE=false

# Option 2: AWS S3
# STORAGE_BACKEND=s3
# STORAGE_ENDPOINT=s3.amazonaws.com
# STORAGE_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
# STORAGE_SECRET_KEY=YOUR_AWS_SECRET_KEY
# STORAGE_SECURE=true
# STORAGE_REGION=us-east-1

# Option 3: Local filesystem (dev only)
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=/tmp/voice-crafter-storage

# ── ML Models ─────────────────────────────────────────────────────────────────
# Device: auto (detects GPU), cpu, cuda, mps (Apple Silicon)
DEVICE=auto
MODELS_DIR=./models

# TTS Model (XTTS-v2 downloads ~1.8GB on first use)
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Detection model checkpoints (download with scripts/download_models.sh)
AASIST_MODEL_PATH=./models/aasist/AASIST.pth
RAWNET2_MODEL_PATH=./models/rawnet2/RawNet2.pth

# ── HuggingFace (optional, for speaker diarization) ──────────────────────────
# Get token at: huggingface.co/settings/tokens
# Must accept pyannote/speaker-diarization-3.1 license at huggingface.co
HF_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ── Payment (Stripe) ─────────────────────────────────────────────────────────
# Get keys at: dashboard.stripe.com
# Leave empty to use free-plan-only mode (plans still work without payment)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_STARTER_MONTHLY=
STRIPE_STARTER_YEARLY=
STRIPE_PRO_MONTHLY=
STRIPE_PRO_YEARLY=
STRIPE_ENTERPRISE_MONTHLY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave empty to skip email sending (logs instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@voicecrafter.ai
SMTP_TLS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FREE_RPM=30
RATE_LIMIT_STARTER_RPM=120
RATE_LIMIT_PRO_RPM=600
RATE_LIMIT_ENTERPRISE_RPM=3000

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_CLONING=true
FEATURE_GENERATION=true
FEATURE_DETECTION=true
FEATURE_STREAMING=true
FEATURE_HUB=true
FEATURE_DIARIZATION=false          # requires HF_TOKEN
FEATURE_FINE_TUNING=true
FEATURE_RED_TEAM=true
FEATURE_BENCHMARKS=true
FEATURE_SOCIAL=true

# ── Frontend (.env in frontend/) ──────────────────────────────────────────────
# VITE_API_URL=http://localhost:8000/api/v1
# VITE_WS_URL=ws://localhost:8000
