# ═══════════════════════════════════════════════════════════════
# Voice-Crafter Platform — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_NAME=Voice-Crafter
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voicecrafter:voicecrafter@localhost:5432/voicecrafter

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage ────────────────────────────────────────────────────
STORAGE_BACKEND=minio         # minio | s3 | local
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_SECURE=false

# For local dev without MinIO:
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=/tmp/voice-crafter

# ── ML Models ──────────────────────────────────────────────────
MODELS_DIR=./models
DEVICE=auto                   # auto | cpu | cuda | mps

# TTS
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Detection (download separately from original repos)
AASIST_MODEL_PATH=./models/aasist/AASIST.pth
RAWNET2_MODEL_PATH=./models/rawnet2/RawNet2.pth

# Diarization (requires HuggingFace account)
DIARIZATION_ENABLED=true
HF_TOKEN=                     # Your HuggingFace token for pyannote

# ── Payment (set when ready to accept payments) ────────────────
PAYMENT_GATEWAY=stripe

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY=
STRIPE_STARTER_YEARLY=
STRIPE_PRO_MONTHLY=
STRIPE_PRO_YEARLY=
STRIPE_ENTERPRISE_MONTHLY=

# ── Email (optional — stubs work without this) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@voicecrafter.ai
SMTP_FROM_NAME=Voice-Crafter

# ── OAuth (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── CORS ───────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
